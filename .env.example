# Copy to .env and fill these in. Generate any *_SECRET with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# NextAuth — required.
AUTH_SECRET=
AUTH_TRUST_HOST=true
# Public canonical URL; redirect targets after login point here.
# AUTH_URL=https://bcon.velocitychs.com

# When set, super-admins with no tenant cookie land on this tenant
# instead of the oldest one in the DB. Slug must exist.
# DEFAULT_TENANT_SLUG=velocity-demo

# Cron token used by /api/cron/* endpoints (rfp-sweep, backup, inspections-sync).
# Required for the nightly backup Task Scheduler entry; without this the
# /api/cron/backup endpoint refuses to run.
CRON_SECRET=

# LLM provider — set ONE of these to enable real AI calls.
# (Without either, AI features fall back to deterministic mocks.)
# ENABLE_LLM_CALLS=true
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: override the SQLite location, or point at Postgres.
# DATABASE_URL=file:./prisma/dev.db
# DATABASE_URL=postgresql://user:pass@host:5432/db?schema=public
