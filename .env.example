# Copy to .env and fill these in. Generate any *_SECRET with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# NextAuth — required. In production the app refuses to boot if this is
# missing or set to a known dev/CI placeholder (see src/lib/env-guard.ts).
AUTH_SECRET=
AUTH_TRUST_HOST=true

# Per-tenant secret encryption key (vault). REQUIRED in production — the
# app refuses to boot if this is missing or equals the dev default, so
# encrypted-at-rest credentials are never protected by a well-known key.
BCON_VAULT_KEY=
# Public canonical URL; redirect targets after login point here.
# AUTH_URL=https://bcon.velocitychs.com

# When set, super-admins with no tenant cookie land on this tenant
# instead of the oldest one in the DB. Slug must exist.
# DEFAULT_TENANT_SLUG=velocity-demo

# Cron token used by /api/cron/* endpoints (rfp-sweep, backup, inspections-sync).
# Required for the nightly backup Task Scheduler entry; without this the
# /api/cron/backup endpoint refuses to run.
CRON_SECRET=

# LLM provider — set ONE of these to enable real AI calls.
# (Without either, AI features fall back to deterministic mocks.)
# ENABLE_LLM_CALLS=true
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: override the SQLite location, or point at Postgres.
# DATABASE_URL=file:./prisma/dev.db
# DATABASE_URL=postgresql://user:pass@host:5432/db?schema=public

# Error monitoring (optional). When set, server errors, failed cron runs,
# dropped audit writes, and client error-boundary hits are POSTed as JSON
# to this webhook (Slack/Discord/Sentry-tunnel/etc.). Without it, errors
# still log to stderr.
# ERROR_WEBHOOK_URL=
# ERROR_REPORT_SOURCE=bcon-prod

# Physical DB backup retention (scripts/db-backup.ts). Default 14 days.
# BACKUP_RETENTION_DAYS=14

# ---------------------------------------------------------------------------
# Object storage (uploads: photos, import artifacts). Default writes to
# ./uploads on local disk. For durable cloud storage set s3 or r2.
# MISCONFIGURATION IS FAIL-CLOSED: in production, choosing s3/r2 without the
# required STORAGE_S3_* vars refuses to boot (src/lib/storage.ts) instead of
# silently writing to local disk.
# STORAGE_TRANSPORT=local
# STORAGE_TRANSPORT=s3
# STORAGE_S3_BUCKET=
# STORAGE_S3_REGION=us-east-1        # R2: auto
# STORAGE_S3_ENDPOINT=               # R2: https://<account-id>.r2.cloudflarestorage.com
# STORAGE_S3_ACCESS_KEY=
# STORAGE_S3_SECRET_KEY=
# STORAGE_S3_PUBLIC_URL=             # optional CDN host for public URLs

# Background job queue. in-process (default) runs jobs inline on this host.
# bullmq is NOT implemented yet — selecting it in production refuses to boot
# rather than silently dropping durability (src/lib/queue.ts).
# QUEUE_TRANSPORT=in-process

# Transactional email. Default transport is "log" (no real sends — messages
# are logged). To send real mail set a transport + key + verified sender.
# NOTE: use a bcon-owned sender domain; never send from braetr.com.
# EMAIL_TRANSPORT=resend
# RESEND_API_KEY=
# EMAIL_TRANSPORT=sendgrid
# SENDGRID_API_KEY=
# EMAIL_FROM=no-reply@bcon.jahdev.com

# SSO (all optional; each provider activates only when its vars are set —
# see src/lib/sso-providers.ts and docs/integrations.md).
# OKTA_CLIENT_ID=
# OKTA_CLIENT_SECRET=
# OKTA_ISSUER=https://<org>.okta.com/oauth2/default
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=
# AUTH0_ISSUER=https://<tenant>.auth0.com

# E-signature for pay applications (DocuSign JWT grant — disabled until ALL
# vars are set; see docs/integrations.md for the one-time consent step).
# ESIGN_PROVIDER=docusign
# DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi
# DOCUSIGN_OAUTH_HOST=account-d.docusign.com   # prod: account.docusign.com
# DOCUSIGN_ACCOUNT_ID=
# DOCUSIGN_INTEGRATION_KEY=
# DOCUSIGN_USER_ID=
# DOCUSIGN_PRIVATE_KEY=                        # RSA PEM; \n-escaped one-liner OK

# Project-site map embed (optional). Without a key the project page still
# shows a plain "Map" link (no key required). With a key it renders an
# inline Google Maps Embed iframe of the site address.
# GOOGLE_MAPS_EMBED_API_KEY=

# Login rate-limit sidecar DB location override (defaults to
# prisma/rate-limit.db; useful for multi-instance hosts/tests).
# RATE_LIMIT_DB_FILE=

# ---------------------------------------------------------------------------
# Microsoft 365 (Graph) — app-only client-credentials integration: outbound
# mail transport (EMAIL_TRANSPORT=m365) + calendar events for pay-app due
# dates. One-time Azure AD setup (Microsoft 365 admin):
#   1. Entra admin center -> App registrations -> New registration
#      (single-tenant).
#   2. API permissions -> Add -> Microsoft Graph -> APPLICATION permissions:
#      Mail.Send + Calendars.ReadWrite -> "Grant admin consent".
#   3. Certificates & secrets -> New client secret -> copy the secret VALUE.
#   4. Fill the four vars below + restart the service.
# MS_SENDER_UPN must be a real, licensed mailbox in the tenant — Graph
# app-only sends/events always originate from an actual mailbox.
# Unset = gracefully disabled (settings page shows setup instructions).
# MS_TENANT_ID=
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=
# MS_SENDER_UPN=no-reply@yourdomain.com
# To route ALL transactional email through Graph:
# EMAIL_TRANSPORT=m365

# ---------------------------------------------------------------------------
# QuickBooks Online — REAL OAuth2 integration (per-tenant connect on
# Settings -> Integrations; tokens encrypted at rest with BCON_VAULT_KEY).
# Create an app at https://developer.intuit.com (QuickBooks Online
# Accounting scope) and register this EXACT redirect URI:
#   https://bcon.jahdev.com/api/integrations/qbo/callback
# (derived from APP_URL — never from the request URL; tunnel rule).
# QBO_ENVIRONMENT selects the Intuit API host: sandbox (default) or
# production. QBO_ITEM_ID is the QBO Item used on pushed invoice lines
# (default "1", usually "Services"). Unset client id/secret = the real
# integration is disabled and the legacy demo connector remains.
# QBO_CLIENT_ID=
# QBO_CLIENT_SECRET=
# QBO_ENVIRONMENT=sandbox
# QBO_ITEM_ID=1
